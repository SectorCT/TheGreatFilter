# Django Configuration
# Use a long random value (>=32 chars). Example:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET_KEY
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOW_ALL_ORIGINS=True

# Database Configuration
DB_NAME=thegreatfilter
DB_USER=postgres
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD
DB_HOST=db
DB_PORT=5432

# Email Configuration (for password reset)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=XXX
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Celery / Redis Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500
GEMSTAT_DATASET_DIR=

# Core simulation service (used by Celery worker)
CORE_SERVICE_URL=http://core:8000

# Postgres env vars required by the postgres Docker image (same values as DB_* above)
POSTGRES_DB=thegreatfilter
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_DB_PASSWORD

# Google OAuth Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
